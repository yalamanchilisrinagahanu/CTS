using System;

class Program
{
    static void MergeSort(int[] arr)
    {
        Array.Sort(arr);

        foreach (int num in arr)
        {
            Console.Write(num + " ");
        }
    }

    static void Main()
    {
        int[] arr = { 38, 27, 43, 3, 9, 82, 10 };

        MergeSort(arr);
    }
}
